generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model posts {
  id              String   @id
  slug            String   @unique(map: "posts_slug_unique")
  title           String
  author          String
  excerpt         String
  content         String
  cover_image_url String
  published       Boolean
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
}
